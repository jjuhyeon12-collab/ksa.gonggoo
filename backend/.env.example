SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - 비워두면 개발용 SQLite 사용. PostgreSQL 사용 시에만 아래 주석 해제.
DATABASE_URL=
# DATABASE_URL=postgresql://user:password@localhost:5432/gonggoo

# Redis (WebSocket용) - 비워두면 개발용 인메모리 모드로 동작
REDIS_URL=

# 이메일 알림 (Gmail) - 매칭 완료 시 참여자에게 메일 발송
# Gmail 2단계 인증 후 "앱 비밀번호"(16자리)를 발급받아 입력하세요.
# 비워두면 실제 발송 대신 서버 콘솔에 메일이 출력됩니다.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# 카카오톡 알림 (Solapi) - 추가모집/매칭 완료 시 "개설자"에게 카카오톡 발송
# https://solapi.com 에서 API 키 발급, 발신번호(SENDER_PHONE) 등록 필요.
# 비워두면 실제 발송 대신 서버 콘솔에 출력됩니다.
KAKAO_API_KEY=
KAKAO_API_SECRET=
KAKAO_SENDER_PHONE=
# 실제 "카카오 알림톡"을 보내려면 아래 2개도 입력하세요. (없으면 문자(SMS)로 대체 발송)
#  - KAKAO_PF_ID      : Solapi에 연동한 카카오 채널 ID (KA01PF...)
#  - KAKAO_TEMPLATE_ID: 승인받은 알림톡 템플릿 ID (KA01TP...) — 템플릿 본문에 #{내용} 변수 1개 사용
KAKAO_PF_ID=
KAKAO_TEMPLATE_ID=
